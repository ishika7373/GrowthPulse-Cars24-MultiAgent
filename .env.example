# Copy this file to `.env` and fill in your real key.
# The system uses OpenAI via LangChain (langchain-openai).
OPENAI_API_KEY=sk-your-openai-key-here

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
GROWTHPULSE_PORT=8000

# If OPENAI_API_KEY is missing or invalid, the system gracefully falls back
# to a deterministic offline mock-LLM so the demo still runs end-to-end.
GROWTHPULSE_FORCE_MOCK=false
