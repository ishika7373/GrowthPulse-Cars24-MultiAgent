# Copy this file to `.env` and fill in your real Gemini key.
# Either GOOGLE_API_KEY or GEMINI_API_KEY is accepted (langchain-google-genai uses GOOGLE_API_KEY natively).
GOOGLE_API_KEY=AIzaSyBr3x7UvsGe8nohSMSZykyQtPpSE-ymKwY

# Optional model overrides
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# Optional UI overrides
GROWTHPULSE_PORT=8000

# If both keys are missing or invalid, the system gracefully falls back
# to a deterministic offline mock LLM so the demo still runs end-to-end.
GROWTHPULSE_FORCE_MOCK=false
